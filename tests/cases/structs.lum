# structs: declaration, construction, field read/write, params/returns, nesting
struct Point {
    x: int,
    y: int,
}

struct Rect {
    lo: Point,
    hi: Point,
}

fn dist_sq(p: Point) -> int {
    return p.x * p.x + p.y * p.y;
}

fn make(x: int, y: int) -> Point {
    return Point { x: x, y: y };
}

fn main() {
    let p = Point { x: 3, y: 4 };
    print p.x;             # 3
    print p.y;             # 4
    print dist_sq(p);      # 25
    p.x = 10;              # field write
    print p.x;             # 10
    print dist_sq(make(6, 8));  # 100

    let r = Rect { lo: Point { x: 0, y: 0 }, hi: Point { x: 5, y: 9 } };
    print r.hi.y;          # 9
    r.hi.y = 99;           # nested field write
    print r.hi.y;          # 99
    return 0;
}
