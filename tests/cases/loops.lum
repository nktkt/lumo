# for loops, break, and continue
fn main() {
    for (let i = 0; i < 4; i = i + 1) {
        print i;            # 0 1 2 3
    }

    # sum of odd numbers 1..=9 using continue (which must still run the step)
    let sum = 0;
    for (let i = 1; i <= 10; i = i + 1) {
        if (i % 2 == 0) {
            continue;
        }
        sum = sum + i;
    }
    print sum;              # 25

    # break out early
    for (let i = 0; i < 100; i = i + 1) {
        if (i == 3) {
            break;
        }
        print i + 10;       # 10 11 12
    }
    return 0;
}
