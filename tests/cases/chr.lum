# chr(): byte -> 1-char string. With s[i] and +, transform strings.
fn reverse(s: string) -> string {
    let r = "";
    for (let i = len(s) - 1; i >= 0; i = i - 1) {
        r = r + chr(s[i]);
    }
    return r;
}

fn upper(s: string) -> string {
    let r = "";
    for (let i = 0; i < len(s); i = i + 1) {
        let c = s[i];
        if (c >= 97 && c <= 122) {   # 'a'..'z'
            c = c - 32;
        }
        r = r + chr(c);
    }
    return r;
}

fn main() {
    print chr(65);                 # A
    print reverse("lumo");         # omul
    print upper("Hello, World!");  # HELLO, WORLD!
    return 0;
}
