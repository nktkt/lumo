# arrays: literals, indexing (read/write), len, arrays as parameters
fn sum(xs: [int]) -> int {
    let total = 0;
    for (let i = 0; i < len(xs); i = i + 1) {
        total = total + xs[i];
    }
    return total;
}

fn main() {
    let a = [10, 20, 30, 40];
    print len(a);          # 4
    print a[0];            # 10
    print a[3];            # 40
    a[1] = 99;             # element assignment
    print a[1];            # 99
    print sum(a);          # 10 + 99 + 30 + 40 = 179

    let fs = [1.5, 2.5, 3.0];
    print fs[2];           # 3
    let words = ["hi", "there"];
    print words[1];        # there
    print len(words);      # 2
    let flags = [true, false, true];
    print flags[0] && flags[2];  # true
    return 0;
}
