# Non-mutating sorted(a) and reversed(a) for arrays.

fn ints(xs: [int]) -> string {
    let r = "";
    for (let i = 0; i < len(xs); i = i + 1) {
        if (i > 0) { r = r + ","; }
        r = r + str(xs[i]);
    }
    return r;
}

fn flts(xs: [float]) -> string {
    let r = "";
    for (let i = 0; i < len(xs); i = i + 1) {
        if (i > 0) { r = r + ","; }
        r = r + str(xs[i]);
    }
    return r;
}

fn main() {
    let a = [3, 1, 4, 1, 5, 9, 2, 6];
    print ints(sorted(a));              # 1,1,2,3,4,5,6,9
    print ints(a);                      # 3,1,4,1,5,9,2,6  (original intact)
    print ints(reversed(a));            # 6,2,9,5,1,4,1,3
    print ints(reversed(sorted(a)));    # 9,6,5,4,3,2,1,1  (descending idiom)

    # strings sort lexicographically (by byte)
    let w = ["banana", "apple", "cherry"];
    print join(sorted(w), ",");         # apple,banana,cherry
    print join(reversed(w), ",");       # cherry,apple,banana

    # floats
    let f = [2.5, 1.0, 3.25, 0.5];
    print flts(sorted(f));              # 0.5,1,2.5,3.25

    # edge cases: single element and empty
    print ints(sorted([42]));           # 42
    let empty: [int] = [];
    print len(sorted(empty));           # 0
    print len(reversed(empty));         # 0

    # reversed works on any element type (here a nested array)
    let g = [[1, 2], [3, 4], [5, 6]];
    print ints(reversed(g)[0]);         # 5,6
    return 0;
}
