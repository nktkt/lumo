# Nested collections: arrays of arrays, maps of arrays, arrays of maps,
# and maps of maps. Element/value types nest arbitrarily; indexing chains.

fn main() {
    # 2D array literal, chained indexing, in-place mutation
    let grid = [[1, 2, 3], [4, 5, 6]];
    print grid[0][0];          # 1
    print grid[1][2];          # 6
    grid[1][0] = 40;
    print grid[1][0];          # 40
    print len(grid);           # 2
    print len(grid[0]);        # 3

    # build a ragged 2D array with push (starting from empty literals)
    let tri: [[int]] = [];
    let r = 0;
    while (r < 3) {
        let row: [int] = [];
        let c = 0;
        while (c <= r) {
            row = push(row, c);
            c = c + 1;
        }
        tri = push(tri, row);
        r = r + 1;
    }
    print len(tri);            # 3
    print len(tri[2]);         # 3
    print tri[2][2];           # 2

    # for-in over the rows of a nested array
    let total = 0;
    for (row in grid) {
        for (x in row) {
            total = total + x;
        }
    }
    print total;               # 1+2+3+40+5+6 = 57

    # map of arrays (group-by style)
    let groups: {string: [int]} = {};
    groups["even"] = [2, 4, 6];
    groups["odd"] = [1, 3];
    groups["odd"] = push(groups["odd"], 5);
    print groups["even"][2];   # 6
    print len(groups["odd"]);  # 3
    print groups["odd"][2];    # 5

    # array of maps
    let recs: [{string: int}] = [{"x": 1, "y": 2}, {"x": 3, "y": 4}];
    print recs[0]["y"];        # 2
    print recs[1]["x"];        # 3

    # map of maps
    let m: {string: {string: int}} = {};
    m["a"] = {"score": 10};
    m["b"] = {"score": 20};
    m["a"]["score"] = 15;
    print m["a"]["score"];     # 15
    print m["b"]["score"];     # 20

    return 0;
}
