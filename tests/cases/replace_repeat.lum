# String replace and repeat.

fn main() {
    # replace(s, from, to) swaps every occurrence of `from` with `to`
    print replace("a.b.c", ".", "-");          # a-b-c
    print replace("aaa", "a", "bb");            # bbbbbb  (expansion)
    print replace("hello", "l", "");            # heo     (deletion)
    print replace("abc", "xyz", "q");           # abc     (no match)
    print replace("one two two", "two", "X");   # one X X (multiple)
    print "[" + replace("", "a", "b") + "]";    # []      (empty input)
    print replace("abc", "", "x");              # abc     (empty from: unchanged)
    print replace("a,b,c", ",", ", ");          # a, b, c

    # repeat(s, n) concatenates n copies; n <= 0 gives ""
    print "[" + repeat("ab", 3) + "]";          # [ababab]
    print "[" + repeat("x", 0) + "]";           # []
    print "[" + repeat("x", -2) + "]";          # []      (negative -> empty)
    print "[" + repeat("", 5) + "]";            # []      (empty source)
    print repeat("=", 10);                       # ==========

    # they compose with the rest of the toolkit
    print to_upper(replace("hi there", " ", "_"));   # HI_THERE
    let bar = repeat("#", len("data"));              # #### (length-driven)
    print bar;
    return 0;
}
