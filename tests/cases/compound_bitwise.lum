# Compound bitwise assignment: &= |= ^= <<= >>=  (desugar of a OP= b).

fn main() {
    let x = 12;
    x &= 10;  print x;          # 8
    x |= 4;   print x;          # 12
    x ^= 5;   print x;          # 9
    x <<= 3;  print x;          # 72
    x >>= 2;  print x;          # 18

    # bit-flags: accumulate with |=, clear with &= ~mask
    let flags = 0;
    flags |= 1;
    flags |= 8;
    print flags;                # 9
    flags &= ~1;
    print flags;                # 8

    # works on array elements and map values (reuses the lvalue paths)
    let a = [1, 2, 3];
    a[1] <<= 4;
    print a[1];                 # 32

    let m: {string: int} = {};
    m["mask"] = 6;
    m["mask"] &= 3;
    print m["mask"];            # 2

    # >>= and <<= don't clash with >= / <=
    let y = 5;
    if (y >= 5) { y >>= 1; }
    print y;                    # 2
    return 0;
}
